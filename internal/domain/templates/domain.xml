<domain type='kvm'{{if .MaxPhysAddrBits}} xmlns:qemu='http://libvirt.org/schemas/domain/qemu/1.0'{{end}}>
  <name>{{.Name}}</name>
{{- if .UUID}}
  <uuid>{{xml .UUID}}</uuid>
{{- end}}
  <metadata>
    <libosinfo:libosinfo xmlns:libosinfo='http://libosinfo.org/xmlns/libvirt/domain/1.0'>
      <libosinfo:os id='http://microsoft.com/win/11'/>
    </libosinfo:libosinfo>
    <orthogonals:guest xmlns:orthogonals='https://github.com/stronautt/orthogonals'>
      <orthogonals:user>{{xml .GuestUser}}</orthogonals:user>
      <orthogonals:password>{{xml .GuestPassword}}</orthogonals:password>
      <orthogonals:locale>{{xml .Locale}}</orthogonals:locale>
      <orthogonals:resolution>{{.Width}}x{{.Height}}</orthogonals:resolution>
      <orthogonals:win11-iso>{{xml .Win11ISO}}</orthogonals:win11-iso>
{{- if .ROMFile}}
      <orthogonals:gpu-rom>{{xml .ROMFile}}</orthogonals:gpu-rom>
{{- end}}
    </orthogonals:guest>
  </metadata>
  <memory unit='MiB'>{{.RAMMiB}}</memory>
  <currentMemory unit='MiB'>{{.RAMMiB}}</currentMemory>
  <!-- 2M hugepages: the qemu hook reserves nr_hugepages before QEMU starts and
       frees them at shutdown; the pool must exist or QEMU cannot map guest RAM. -->
  <memoryBacking>
    <hugepages>
      <page size='2' unit='M'/>
    </hugepages>
  </memoryBacking>
  <vcpu placement='static'>{{.VCPUs}}</vcpu>
  <iothreads>1</iothreads>
  <cputune>
{{- range .VCPUPins}}
    <vcpupin vcpu='{{.VCPU}}' cpuset='{{.CPU}}'/>
{{- end}}
    <emulatorpin cpuset='{{.EmulatorPin}}'/>
    <iothreadpin iothread='1' cpuset='{{.IOThreadPin}}'/>
  </cputune>
  <os firmware='efi'>
    <type arch='x86_64' machine='q35'>hvm</type>
    <firmware>
      <feature enabled='yes' name='enrolled-keys'/>
      <feature enabled='yes' name='secure-boot'/>
    </firmware>
    <loader secure='yes'/>
  </os>
  <features>
    <acpi/>
    <apic/>
    <hyperv mode='custom'>
      <relaxed state='on'/>
      <vapic state='on'/>
      <spinlocks state='on' retries='8191'/>
      <vpindex state='on'/>
      <runtime state='on'/>
      <synic state='on'/>
      <stimer state='on'>
        <direct state='on'/>
      </stimer>
      <frequencies state='on'/>
      <tlbflush state='on'/>
      <ipi state='on'/>
    </hyperv>
    <smm state='on'/>
  </features>
  <cpu mode='host-passthrough' check='none' migratable='off'>
    <topology sockets='1' cores='{{.Cores}}' threads='{{.ThreadsPerCore}}'/>
    <cache mode='passthrough'/>
{{- if .MaxPhysAddrBits}}
    <maxphysaddr mode='emulate' bits='{{.MaxPhysAddrBits}}'/>
{{- end}}
  </cpu>
  <clock offset='localtime'>
    <timer name='rtc' tickpolicy='catchup'/>
    <timer name='pit' tickpolicy='delay'/>
    <timer name='hpet' present='no'/>
    <timer name='hypervclock' present='yes'/>
  </clock>
  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>destroy</on_crash>
  <pm>
    <suspend-to-mem enabled='no'/>
    <suspend-to-disk enabled='no'/>
  </pm>
  <devices>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2' cache='none' io='io_uring' discard='unmap' iothread='1'/>
      <source file='{{.DiskPath}}'/>
      <target dev='vda' bus='virtio'/>
      <boot order='1'/>
    </disk>
{{- if .Win11ISO}}
    <disk type='file' device='cdrom'>
      <driver name='qemu' type='raw'/>
      <source file='{{.Win11ISO}}' startupPolicy='optional'/>
      <target dev='sda' bus='sata'/>
      <readonly/>
      <boot order='2'/>
    </disk>
{{- end}}
{{- if .VirtioISO}}
    <disk type='file' device='cdrom'>
      <driver name='qemu' type='raw'/>
      <source file='{{.VirtioISO}}' startupPolicy='optional'/>
      <target dev='sdb' bus='sata'/>
      <readonly/>
    </disk>
{{- end}}
{{- if .ProvisionISO}}
    <disk type='file' device='cdrom'>
      <driver name='qemu' type='raw'/>
      <source file='{{.ProvisionISO}}' startupPolicy='optional'/>
      <target dev='sdc' bus='sata'/>
      <readonly/>
    </disk>
{{- end}}
    <interface type='network'>
      <source network='default'/>
      <model type='virtio'/>
    </interface>
    <channel type='unix'>
      <target type='virtio' name='org.qemu.guest_agent.0'/>
    </channel>
    <!-- spice-vdagent's transport: without it the guest has no clipboard, and
         Looking Glass takes its clipboard from SPICE too -->
    <channel type='spicevmc'>
      <target type='virtio' name='com.redhat.spice.0'/>
    </channel>
    <input type='tablet' bus='usb'/>
    <!-- Looking Glass sends raw input through the virtio pair; the usb
         tablet remains the absolute-pointer path for plain SPICE sessions -->
    <input type='mouse' bus='virtio'/>
    <input type='keyboard' bus='virtio'/>
    <graphics type='spice' autoport='yes'>
      <listen type='address'/>
    </graphics>
    <!-- guest audio reaches the Looking Glass client over SPICE; the dGPU's
         HDA function only drives an attached HDMI/DP sink, and this card
         runs headless -->
    <sound model='ich9'>
      <audio id='1'/>
    </sound>
    <audio id='1' type='spice'/>
    <!-- install-time display: Windows OOBE crash-loops with zero display
         adapters, and inline definition is what lands qxl on the canonical
         primary-video slot where OVMF produces a GOP framebuffer (an edit
         into an existing topology gets parked behind a root port and the
         guest renders to nowhere). up flips this to model=none once
         provisioning completes, and a redefine of a provisioned domain
         renders none directly — Looking Glass needs the VDD monitor to be
         the guest's only display. -->
    <video>
{{- if .VideoNone}}
      <model type='none'/>
{{- else}}
      <model type='qxl'/>
{{- end}}
    </video>
    <hostdev mode='subsystem' type='pci' managed='no'>
      <source>
        <address domain='0x{{.GPU.Domain}}' bus='0x{{.GPU.Bus}}' slot='0x{{.GPU.Slot}}' function='0x{{.GPU.Function}}'/>
      </source>
      <!-- bar='off': OVMF hangs executing the option ROM; the Windows driver
           needs no ROM BAR. gpu-rom overrides with a vBIOS for MUXless dGPUs. -->
{{- if .ROMFile}}
      <rom file='{{xml .ROMFile}}'/>
{{- else}}
      <rom bar='off'/>
{{- end}}
    </hostdev>
{{- if .Audio}}
    <hostdev mode='subsystem' type='pci' managed='no'>
      <source>
        <address domain='0x{{.Audio.Domain}}' bus='0x{{.Audio.Bus}}' slot='0x{{.Audio.Slot}}' function='0x{{.Audio.Function}}'/>
      </source>
    </hostdev>
{{- end}}
    <shmem name='looking-glass'>
      <model type='ivshmem-plain'/>
      <size unit='M'>{{.IVSHMEMMiB}}</size>
    </shmem>
    <tpm model='tpm-crb'>
      <backend type='emulator' version='2.0'/>
    </tpm>
    <memballoon model='none'/>
  </devices>
{{- if .MaxPhysAddrBits}}
  <qemu:commandline>
    <qemu:arg value='-fw_cfg'/>
    <qemu:arg value='opt/ovmf/X-PciMmio64Mb,string=65536'/>
  </qemu:commandline>
{{- end}}
</domain>
