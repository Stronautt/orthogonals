# Integration-tier image: clean fedora:44 with only the test's own needs.
# The orthogonals binary is built on the host (make test-integration) and
# copied in; every system binary it shells out to is faked by run-test.sh.
FROM registry.fedoraproject.org/fedora:44
RUN dnf -y install diffutils python3 && dnf clean all
COPY orthogonals /usr/local/bin/orthogonals
COPY fixture-root /usr/local/share/orthogonals-fixture
COPY run-test.sh /usr/local/bin/orthogonals-integration-test
CMD ["bash", "/usr/local/bin/orthogonals-integration-test"]
